{
  "name": "Ubuntu",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "version": "2.34.0",
      "extraNixConfig": "extra-experimental-features = nix-command flakes"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "jnoortheen.nix-ide",
        "redhat.vscode-yaml",
        "task.vscode-task",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.rulers": [120],
        "editor.quickSuggestions": {
          "strings": "on"
        },
        "files.autoSave": "afterDelay",
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nixd",
        "nix.serverSettings": {
          "nixd": {
            "formatting": {
              "command": ["nixfmt"]
            }
          }
        }
      }
    }
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,readonly,type=bind"
  ],
  "initializeCommand": {
    "mkdir-ssh": "mkdir -p ${localEnv:HOME}${localEnv:USERPROFILE}/.ssh || true"
  },
  "onCreateCommand": "git add \"flake.nix\" && nix profile add .#devEnvironment"
}
